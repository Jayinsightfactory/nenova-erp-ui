{
  "id": "week-pivot-distribution",
  "title": "차수피벗 업체 분배수량 변경 계약",
  "scope": [
    "pages/shipment/week-pivot.js",
    "pages/api/shipment/adjust.js",
    "pages/api/shipment/stock-status.js",
    "pages/api/shipment/start-stock-text.js",
    "lib/pivotAdjustmentPolicy.js"
  ],
  "businessIdentity": ["OrderYear", "OrderWeek", "CustKey", "ProdKey"],
  "actions": [
    {
      "name": "ADD_WITHOUT_ACTIVE_ORDER",
      "orderDetail": "create-positive",
      "shipmentDetail": "increase"
    },
    {
      "name": "ADD_WITH_ACTIVE_ORDER",
      "orderDetail": "preserve",
      "shipmentDetail": "increase"
    },
    {
      "name": "CANCEL",
      "orderDetail": "preserve",
      "shipmentDetail": "decrease"
    }
  ],
  "crossYearFixture": {
    "required": true,
    "description": "2025와 2026에 같은 OrderWeek·CustKey·ProdKey가 있을 때 2026 요청은 2026 행만 읽고 쓴다."
  },
  "requiredTestFiles": [
    "__tests__/shipmentPivotAdjustContract.test.js",
    "__tests__/erpContractManifest.test.js"
  ],
  "requiredCommands": [
    "npm run test:erp-contract",
    "npm run guard:erp-writes -- --changed-from HEAD^",
    "npm run build"
  ]
}
