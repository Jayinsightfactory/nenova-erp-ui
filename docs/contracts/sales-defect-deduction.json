    },
    {
      "name": "REGISTER_ESTIMATE_DEDUCTION",
      "orderDetail": "preserve",
      "shipmentDetail": "preserve",
      "sideEffect": "Estimate INSERT/UPDATE only; no shipment fix cycle"
    },
    {
      "name": "DELETE_ESTIMATE_DEDUCTION",
      "orderDetail": "preserve",
      "shipmentDetail": "preserve",
      "sideEffect": "Estimate DELETE + web soft-delete/history"
    }
  ],
  "crossYearFixture": {
    "required": true,
    "description": "같은 29차가 여러 연도에 있어도 선택한 OrderYear의 target ShipmentMaster와 전년도 경계(01차면 전년도 52차)만 사용한다. 29차 등록 단가는 같은 연도 28차 분배 단가를 사용한다."
  },
  "dnspyEvidence": {
    "required": true,
    "record": "docs/exe-golden/FormEstimateView.md",
