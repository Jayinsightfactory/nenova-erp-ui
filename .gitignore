# 빌드 출력 — Railway에서 직접 빌드하도록 제외
.next/
out/

# 환경변수 — 보안상 제외
.env
.env.local
.env*.local

# 의존성
node_modules/

# 기타
.DS_Store
*.log

# 로컬 preview 용 임시 파일
.preview/
data/.train-queue.json
*.product-cache.json

# .claude/ — 문서 3종(CLAUDE/PLAN/PROGRESS)은 커밋, 나머지는 사용자별 상태
.claude/settings.local.json
.claude/launch.json
.claude/worktrees/

# 런타임 업로드 파일 (카카오워크 봇 이미지 등) — 커밋 금지, .gitkeep 만 추적
public/uploads/photos/**
!public/uploads/photos/.gitkeep
data/order-mappings.backup-*.json
data/audit-bills-result.json
data/product-master-diagnosis.json
data/category-overrides.backup-*.json
data/product-master-rollback-*.sql

# 영업매출관리 — 이카운트 조회 결과/매칭/수정 런타임 저장본 (서버에서 생성, 커밋 금지)
# (단, data/sales-revenue-history-seed.json 은 과거 데이터 시드라 커밋 대상)
data/sales-revenue-batches.json
data/sales-revenue-customer-mappings.json
data/sales-revenue-cells.json
data/sales-revenue-cell-history.json

# 카탈로그 이미지 — 런타임 업로드 + 인덱스 (커밋 금지)
data/catalog-images.json
data/catalog-arrival-overrides.json
public/uploads/catalog/**
!public/uploads/catalog/.gitkeep
!public/uploads/catalog/_bulk_import/.gitkeep

